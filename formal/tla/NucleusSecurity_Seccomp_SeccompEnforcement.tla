    /\ pc = 0
    /\ history = <<>>
    /\ event_queue = <<>>
    /\ allowed_syscalls = Syscalls
    /\ default_allow = TRUE
    /\ seccomp_fail_closed = FALSE
    /\ no_new_privileges = FALSE

\* Transition actions
no_filter_apply_seccomp_filter ==
