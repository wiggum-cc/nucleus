    "io_uring_setup"
}

EssentialSyscalls == {
    "read",
    "write",
    "open",
    "close",
    "exit",
    "exit_group"
}

Syscalls == DangerousSyscalls \cup EssentialSyscalls

VARIABLES
    \* @type: Str;
