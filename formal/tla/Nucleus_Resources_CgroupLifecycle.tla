    /\ pc' = pc + 1
    /\ history' = Append(history, state)
    /\ pending' = pending

created_cleanup_failed_cgroup ==
    /\ state = created
    /\ state' = removed
    /\ pc' = pc + 1
    /\ history' = Append(history, state)
