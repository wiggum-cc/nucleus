    /\ pc' = pc + 1
    /\ history' = Append(history, state)
    /\ pending' = pending

attached_start_monitoring ==
    /\ state = attached
    /\ state' = monitoring
    /\ pc' = pc + 1
    /\ history' = Append(history, state)
    /\ pending' = pending

monitoring_cleanup ==
    /\ state = monitoring
